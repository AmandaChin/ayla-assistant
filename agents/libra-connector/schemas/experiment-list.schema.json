{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ayla Libra Experiment List",
  "type": "object",
  "required": ["route", "code", "count", "rows"],
  "properties": {
    "route": {
      "type": "string",
      "description": "Connector route used to fetch the data."
    },
    "visible": {
      "type": "boolean",
      "description": "Whether the browser window was shown for manual SSO/debugging."
    },
    "code": {
      "type": "integer",
      "description": "Libra API response code."
    },
    "message": {
      "type": "string"
    },
    "count": {
      "type": "integer",
      "description": "Number of experiments returned by the page API before local limit is applied."
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": {
            "type": ["integer", "string"]
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "status_code": {
            "type": ["integer", "string", "null"]
          },
          "owners": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "creator": {
            "type": "string"
          },
          "created_time": {
            "type": "string"
          },
          "start_time": {
            "type": "string"
          },
          "end_time": {
            "type": "string"
          },
          "app_id": {
            "type": ["integer", "string"]
          },
          "product_name": {
            "type": "string"
          },
          "layer_name": {
            "type": "string"
          },
          "is_reversal": {
            "type": "boolean"
          },
          "reversal_type": {
            "type": ["integer", "string", "null"]
          },
          "reversal_label": {
            "type": "string"
          },
          "reversal_key": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
