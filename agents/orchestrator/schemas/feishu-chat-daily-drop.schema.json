{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ayla.local/schemas/feishu-chat-daily-drop.schema.json",
  "title": "Ayla Feishu Chat Daily Drop",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "kind",
    "date",
    "batch_id",
    "idempotency_key",
    "created_at",
    "producer",
    "messages"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ayla.feishu_chat.daily.v1"
    },
    "kind": {
      "type": "string",
      "const": "feishu_chat_daily_batch"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["feishu_bot", "openclaw_agent", "relay", "manual_export"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bot_app_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "$ref": "#/$defs/message"
      }
    }
  },
  "$defs": {
    "message": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "message_id",
        "created_at",
        "chat",
        "sender",
        "content_type",
        "content"
      ],
      "properties": {
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "idempotency_key": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string"
        },
        "chat": {
          "type": "object",
          "additionalProperties": true,
          "required": ["chat_id", "chat_name", "chat_type"],
          "properties": {
            "chat_id": {
              "type": "string",
              "minLength": 1
            },
            "chat_name": {
              "type": "string",
              "minLength": 1
            },
            "chat_type": {
              "type": "string",
              "enum": ["group", "direct", "p2p", "single", "unknown"]
            }
          }
        },
        "sender": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string"
            }
          }
        },
        "content_type": {
          "type": "string",
          "enum": ["text", "post", "image", "file", "audio", "video", "mixed", "unknown"]
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "plain_text": {
          "type": "string"
        },
        "mentions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "is_me": {
                "type": "boolean"
              }
            }
          }
        },
        "mentioned_me": {
          "type": "boolean"
        },
        "reply_to_me": {
          "type": "boolean"
        },
        "authored_by_me": {
          "type": "boolean"
        },
        "thread_id": {
          "type": "string"
        },
        "root_message_id": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ayla_hints": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "importance": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "reason": {
              "type": "string"
            },
            "suggested_target": {
              "type": "string",
              "enum": ["todo", "note", "work_record", "report_material", "memo", "ignore"]
            },
            "project": {
              "type": "string"
            }
          }
        },
        "raw": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
