{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ayla.local/schemas/orchestrator-ingest-payload.schema.json",
  "title": "Ayla Orchestrator Ingest Payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["raw_input", "intent", "summary", "candidates", "questions", "tool_actions"],
  "properties": {
    "source": {
      "type": "string",
      "default": "openclaw_agent"
    },
    "author": {
      "type": "string",
      "default": "ayla-orchestrator"
    },
    "raw_input": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": ["capture", "task", "public_knowledge", "work_record", "query", "summary", "external_action"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tool_actions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "input_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_url": {
      "type": "string"
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "title",
        "content",
        "storage_target",
        "visibility",
        "tags",
        "source_refs",
        "risk_level",
        "requires_confirmation",
        "confidence"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["todo", "public_note", "work_record", "report_material", "pinned", "memo"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "storage_target": {
          "type": "string",
          "enum": ["local_state", "feishu_doc", "obsidian_public_vault"]
        },
        "visibility": {
          "type": "string",
          "enum": ["private", "internal", "public"]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "requires_confirmation": {
          "type": "boolean"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "due_at": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "normal", "medium", "high", "urgent"]
        },
        "project": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "reasoning_hint": {
          "type": "string"
        }
      }
    }
  }
}
